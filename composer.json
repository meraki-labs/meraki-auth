{
  "name": "merakilab/meraki-auth",
  "description": "Authentication package for the MerakiLabs ecosystem",
  "version": "dev-main",
  "type": "library",
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "Meraki\\Packages\\Auth\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Meraki\\Packages\\Auth\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Meraki\\Packages\\Auth\\AuthServiceProvider"
      ],
      "aliases": {
        "MerakiAuth": "Meraki\\Packages\\Auth\\Facades\\MerakiAuth"
      }
    }
  },
  "authors": [
    {
      "name": "DatPA",
      "email": "datpa@merakilabs.tech"
    }
  ],
  "require": {
    "php": "^8.2",
    "laravel/framework": "^12.0",
    "laravel/sanctum": "^4.0",
    "merakilab/meraki-core": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "orchestra/testbench": "^10.0",
    "mockery/mockery": "^1.6"
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "repositories": {
    "meraki-core": {
      "type": "path",
      "url": "/Users/Shared/Development/MerakiLabs/meraki-core"
    }
  }
}
