{
  "name": "merakilab/meraki-auth",
  "description": "Authentication package for the MerakiLabs ecosystem",
  "version": "dev-main",
  "type": "library",
  "license": "MIT",
  "minimum-stability": "dev",
  "prefer-stable": true,
  "autoload": {
    "psr-4": {
      "Meraki\\Packages\\Auth\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Meraki\\Packages\\Auth\\AuthServiceProvider"
      ],
      "aliases": {
        "MerakiAuth": "Meraki\\Packages\\Auth\\Facades\\MerakiAuth",
        "MerakiAuthDriver": "Meraki\\Packages\\Auth\\Facades\\MerakiAuthDriver"
      }
    }
  },
  "authors": [
    {
      "name": "DatPA",
      "email": "datpa@merakilabs.tech"
    }
  ],
  "require": {
    "php": "^8.2",
    "laravel/framework": "^12.0",
    "merakilab/meraki-core": "*"
  },
  "require-dev": {
    "orchestra/testbench": "^10.0",
    "phpunit/phpunit": "^11.0"
  },
  "autoload-dev": {
    "psr-4": {
      "Meraki\\Packages\\Auth\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "vendor/bin/phpunit"
  }
}
